---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';

const phoneNumber = '13450853338';

const contactMethods = [
  { icon: 'phone', title: 'Phone / SMS', primary: phoneNumber, href: `tel:${phoneNumber}`, desc: 'Call directly during business hours for technical and procurement questions.' },
  { icon: 'chat', title: 'WeChat (same number)', primary: phoneNumber, href: `weixin://`, desc: 'Same number as phone. Add us to send text, photos, files, video, voice.' },
  { icon: 'social', title: 'Xiaohongshu', primary: 'Search "Xiangfa Shun Plastic"', href: 'https://www.xiaohongshu.com/', desc: 'Follow our account to see factory daily, product photos and customer cases.' },
  { icon: 'video', title: 'Douyin', primary: 'Search "Xiangfa Shun Plastic"', href: 'https://www.douyin.com/', desc: 'Follow our account to see production process and workshop footage.' },
];

const inquiryList = [
  'Company name / contact / contact info',
  'Usage scenario (e.g., building wire, power cord jacket, electronic wire, outdoor wiring…)',
  'Wire spec (conductor cross-section, insulation thickness, sheath thickness)',
  'Key performance requirements (temp / flame retardant / cold-resistant / hardness / color / transparency)',
  'Applicable standard (GB / UL / VDE / other)',
  'Estimated monthly / annual volume',
  'Processing method (extrusion speed, die specs)',
  'Other special requirements (odor, anti-yellowing, ROHS / REACH, etc.)',
];

const svgIcons: Record<string, string> = {
  phone: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>`,
  chat: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>`,
  social: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="3"></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor"></circle></svg>`,
  video: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>`,
};
---
<BaseLayout
  title="Contact Us"
  description="Contact Foshan Xiangfa Shun Plastic Co., Ltd.: Tel/WeChat 13450853338, Xiaohongshu / Douyin search 'Xiangfa Shun Plastic'. Located in Sanshui District, Foshan, China. Inquiry requires usage scenario, performance requirements, specs and volume."
  locale="en"
  breadcrumbs={[
    { name: 'Home', href: '/en/' },
    { name: 'Contact', href: '/en/contact/' },
  ]}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact Foshan Xiangfa Shun Plastic Co., Ltd.',
    description: 'Foshan PVC wire & cable compound manufacturer contact info',
    mainEntity: {
      '@type': 'LocalBusiness',
      name: 'Foshan Xiangfa Shun Plastic Co., Ltd.',
      telephone: '+86-13450853338',
      url: 'https://xfspvc.com/en/',
      address: {
        '@type': 'PostalAddress',
        addressRegion: 'Guangdong',
        addressLocality: 'Sanshui District, Foshan',
        addressCountry: 'CN',
      },
    },
  }}
>
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/en/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <span>Contact</span>
      </nav>
      <div class="section-eyebrow page-eyebrow">CONTACT · 4 CHANNELS</div>
      <h1>Contact Us</h1>
      <p class="page-header-sub">
        WeChat / phone same number. Text, photos, files, video and voice all welcome.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        {contactMethods.map((m) => (
          <a href={m.href} class="contact-card">
            <div class="contact-icon" set:html={svgIcons[m.icon]} />
            <h3 class="contact-title">{m.title}</h3>
            <div class="contact-primary">{m.primary}</div>
            <p class="contact-desc">{m.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="qr-block">
        <div class="qr-card">
          <div class="qr-placeholder" aria-label="WeChat QR placeholder">
            <div class="qr-pattern">
              <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="100" height="100" fill="#fff"/>
