<style>
  .page-eyebrow { margin-bottom: var(--sp-3); }

  .contact-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--sp-4); }

  .contact-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-6);
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: all 0.28s var(--ease-out);
  }

  .contact-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    color: inherit;
    transform: translateY(-4px);
  }

  .contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, var(--color-primary-soft) 0%, #d3e2d8 100%);
    color: var(--color-primary);
    border-radius: 50%;
    margin: 0 auto var(--sp-4);
  }

  .contact-icon svg { width: 26px; height: 26px; }
  .contact-card:hover .contact-icon { background: var(--color-accent); color: #fff; transform: rotate(-6deg); }

  .contact-title { font-size: var(--fs-md); color: var(--color-primary-dark); margin-bottom: var(--sp-2); }
  .contact-primary { font-size: var(--fs-md); color: var(--color-accent); font-weight: 700; margin-bottom: var(--sp-3); font-feature-settings: 'tnum'; letter-spacing: 0.02em; }
  .contact-desc { font-size: var(--fs-sm); color: var(--color-text-soft); margin: 0; line-height: 1.7; }

  .qr-block { display: grid; grid-template-columns: 1fr 1.5fr; gap: var(--sp-6); align-items: stretch; }

  .qr-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-6);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: var(--shadow-xs);
  }

  .qr-placeholder {
    width: 220px;
    height: 220px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    margin-bottom: var(--sp-4);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #fff;
    overflow: hidden;
    position: relative;
  }

  .qr-pattern { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
  .qr-pattern svg { width: 100%; height: 100%; }

  .qr-label {
    position: absolute;
    bottom: 8px;
    left: 8px;
    font-size: 10px;
    background: var(--color-primary);
    color: #fff;
    padding: 2px 6px;
    border-radius: 3px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .qr-placeholder small {
    position: absolute;
    bottom: 8px;
    right: 8px;
    font-size: 9px;
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.9);
    padding: 2px 6px;
    border-radius: 3px;
    max-width: 140px;
    text-align: right;
  }

  .qr-card h3 { color: var(--color-primary-dark); margin-bottom: var(--sp-2); font-size: var(--fs-md); }
  .qr-card p { color: var(--color-text-soft); font-size: var(--fs-sm); margin: 0; }

  .info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-7);
    box-shadow: var(--shadow-xs);
  }

  .info-card h3 { color: var(--color-primary-dark); margin-bottom: var(--sp-5); padding-bottom: var(--sp-3); border-bottom: 2px solid var(--color-accent); font-size: var(--fs-lg); }

  .info-list { list-style: none; padding: 0; margin: 0 0 var(--sp-5); }
  .info-list li { display: flex; padding: var(--sp-4) 0; border-bottom: 1px dashed var(--color-border); font-size: var(--fs-sm); color: var(--color-text-soft); align-items: flex-start; }
  .info-list li:last-child { border-bottom: none; }
  .info-list strong { width: 130px; color: var(--color-text); font-weight: 700; flex-shrink: 0; }
  .info-list a { color: var(--color-accent); font-weight: 700; font-feature-settings: 'tnum'; }

  .info-cta { text-align: center; }

  .inquiry-list-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-7);
    box-shadow: var(--shadow-xs);
  }

  .inquiry-checklist { columns: 2; column-gap: var(--sp-6); margin: 0 0 var(--sp-5); padding-left: 1.5em; }
  .inquiry-checklist li { margin-bottom: var(--sp-3); color: var(--color-text-soft); line-height: 1.7; break-inside: avoid; }

  .inquiry-tip {
    background: var(--color-accent-soft);
    border-left: 4px solid var(--color-accent);
    padding: var(--sp-5);
    border-radius: var(--radius-sm);
    margin-top: var(--sp-4);
  }

  .inquiry-tip h4 { color: var(--color-accent-dark); margin-bottom: var(--sp-3); font-size: var(--fs-base); display: flex; align-items: center; gap: 8px; }
  .tip-icon { font-size: 18px; }
  .inquiry-tip ul { margin: 0; color: var(--color-text-soft); font-size: var(--fs-sm); padding-left: 1.5em; }
  .inquiry-tip li { margin-bottom: 6px; line-height: 1.75; }

  @media (max-width: 1000px) { .contact-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 720px) {
    .contact-grid, .qr-block { grid-template-columns: 1fr; }
    .inquiry-checklist { columns: 1; }
    .info-list strong { width: 110px; }
  }
</style>