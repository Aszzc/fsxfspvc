---
interface Props {
  locale?: 'zh-CN' | 'en';
}

const { locale = 'zh-CN' } = Astro.props;
const isEn = locale === 'en';
const phoneNumber = '13450853338';
const year = new Date().getFullYear();

const products = isEn
  ? [
      ['70°C Insulation', '/en/products/#insulation-70'],
      ['Sheath Compound', '/en/products/#sheath'],
      ['Electronic Wire Compound', '/en/products/#electronic'],
      ['Plug Compound', '/en/products/#plug'],
    ]
  : [
      ['70°C 绝缘料', '/products/#insulation-70'],
      ['PVC 护套料', '/products/#sheath'],
      ['电子线料', '/products/#electronic'],
      ['插头注塑料', '/products/#plug'],
    ];

const pages = isEn
  ? [
      ['Manufacturing', '/en/manufacturing/'],
      ['About', '/en/about/'],
      ['Knowledge', '/en/knowledge/'],
      ['Contact', '/en/contact/'],
    ]
  : [
      ['制造能力', '/manufacturing/'],
      ['关于我们', '/about/'],
      ['行业知识', '/knowledge/'],
      ['联系我们', '/contact/'],
    ];
---

<footer class="site-footer">
  <div class="footer-cta">
    <div class="container footer-cta-inner">
      <div>
        <h2>{isEn ? 'Need PVC compound samples or quotation?' : '需要 PVC 线缆料试样或报价？'}</h2>
        <p>{isEn ? 'Talk directly with the factory team.' : '直接联系工厂，沟通用途、指标、颜色和预计用量。'}</p>
      </div>
      <a class="btn btn-phone btn-lg" href={`tel:${phoneNumber}`}>{phoneNumber}</a>
    </div>
  </div>
  <div class="container footer-main">
    <div class="footer-grid">
      <section>
        <h3>{isEn ? 'Xiangfa Shun Plastic' : '湘发顺塑料'}</h3>
        <p>
          {isEn
            ? 'Foshan PVC wire and cable compound manufacturer with in-house formulation, mixing, extrusion pelletizing and stable batch supply.'
            : '佛山 PVC 电线电缆料生产厂家，自有配方研发、混料、挤出造粒、筛分包装能力，服务线缆与电气制造客户。'}
        </p>
      </section>
      <section>
        <h4>{isEn ? 'Products' : '产品目录'}</h4>
        {products.map(([label, href]) => <a href={href}>{label}</a>)}
      </section>
      <section>
        <h4>{isEn ? 'Company' : '企业信息'}</h4>
        {pages.map(([label, href]) => <a href={href}>{label}</a>)}
      </section>
      <section>
        <h4>{isEn ? 'Contact' : '联系方式'}</h4>
        <p>{isEn ? 'Tel / WeChat' : '电话 / 微信'}：<a href={`tel:${phoneNumber}`}>{phoneNumber}</a></p>
        <p>{isEn ? 'Factory' : '工厂地址'}：{isEn ? 'Sanshui District, Foshan, Guangdong' : '广东佛山三水区'}</p>
        <p>{isEn ? 'Hours' : '业务时间'}：{isEn ? 'Mon-Sat 8:00-18:00' : '周一至周六 8:00-18:00'}</p>
      </section>
    </div>
    <div class="footer-bottom">
      <span>© {year} {isEn ? 'Foshan Sanshui Xiangfa Shun Plastic Co., Ltd.' : '佛山市三水湘发顺塑料有限公司'}</span>
      <span>xfspvc.com</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-primary-dark);
    color: rgba(255, 255, 255, 0.72);
  }

  .footer-cta {
    background: #132f29;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-5);
    padding-top: var(--sp-6);
    padding-bottom: var(--sp-6);
  }

  .footer-cta h2,
  .footer-main h3,
  .footer-main h4 {
    color: #fff;
  }

  .footer-cta h2 {
    font-size: 28px;
    margin-bottom: 4px;
  }

  .footer-cta p,
  .footer-main p {
    margin: 0;
  }

  .footer-main {
    padding-top: var(--sp-7);
    padding-bottom: var(--sp-4);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: var(--sp-6);
  }

  .footer-grid section {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-grid a {
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
  }

  .footer-grid a:hover {
    color: #fff;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
    margin-top: var(--sp-6);
    padding-top: var(--sp-4);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 13px;
    color: rgba(255, 255, 255, 0.52);
  }

  @media (max-width: 900px) {
    .footer-cta-inner,
    .footer-grid {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 620px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
