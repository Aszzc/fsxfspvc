---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import { sortedDailyUpdates } from '../../data/updates';

const latest = sortedDailyUpdates[0];
---
<BaseLayout
  title="PVC Wire & Cable Compound Daily Updates"
  description="Daily updates about PVC wire and cable compound selection, inquiry, sample trial, batch stability, cold and heat resistance, and factory production knowledge."
  canonical="https://xfspvc.com/en/updates/"
  locale="en"
  breadcrumbs={[
    { name: 'Home', href: '/en/' },
    { name: 'Updates', href: '/en/updates/' },
  ]}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Blog',
    '@id': 'https://xfspvc.com/en/updates/#blog',
    name: 'PVC Wire & Cable Compound Daily Updates',
    description: 'PVC compound selection, inquiry, sample trial and factory production updates.',
    url: 'https://xfspvc.com/en/updates/',
    inLanguage: 'en',
    dateModified: latest.date,
    blogPost: sortedDailyUpdates.map((item) => ({
      '@type': 'BlogPosting',
      headline: item.en.title,
      datePublished: item.date,
      dateModified: item.date,
      url: `https://xfspvc.com/en/updates/${item.slug}/`,
      description: item.en.summary,
    })),
  }}
>
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/en/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <span>Updates</span>
      </nav>
      <div class="section-eyebrow page-eyebrow">DAILY UPDATES</div>
      <h1>PVC Wire & Cable Compound Daily Updates</h1>
      <p class="page-header-sub">
        Short factory knowledge updates for material selection, inquiry, sampling and production notes.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionTitle
        eyebrow="LATEST"
        title="Recent Updates"
        subtitle="One useful, specific and verifiable factory knowledge note per day is better than keyword stuffing"
      />
      <div class="updates-grid">
        {sortedDailyUpdates.map((item) => (
          <article class="update-card">
            <div class="update-meta">
              <time datetime={item.date}>{item.date}</time>
              <span>{item.en.category}</span>
            </div>
            <h2><a href={`/en/updates/${item.slug}/`}>{item.en.title}</a></h2>
            <p>{item.en.summary}</p>
            <div class="tag-list">
              {item.en.tags.map((tag) => <span>{tag}</span>)}
            </div>
            <a class="read-more" href={`/en/updates/${item.slug}/`}>Read more</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-eyebrow { margin-bottom: var(--sp-3); }
  .updates-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-4); }
  .update-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-5);
    box-shadow: var(--shadow-xs);
    transition: all 0.22s var(--ease-out);
  }
  .update-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-sm); border-color: var(--color-primary); }
  .update-meta {
    display: flex;
    justify-content: space-between;
    gap: var(--sp-3);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    margin-bottom: var(--sp-3);
  }
  .update-card h2 { font-size: var(--fs-lg); margin-bottom: var(--sp-3); color: var(--color-primary-dark); }
  .update-card p { color: var(--color-text-soft); font-size: var(--fs-sm); line-height: 1.75; }
  .tag-list { display: flex; flex-wrap: wrap; gap: 6px; margin: var(--sp-4) 0; }
  .tag-list span {
    background: var(--color-primary-soft);
    color: var(--color-primary-dark);
    border-radius: 999px;
    padding: 4px 10px;
    font-size: var(--fs-xs);
    font-weight: 600;
  }
  .read-more { font-weight: 700; color: var(--color-accent-dark); }
  @media (max-width: 900px) { .updates-grid { grid-template-columns: 1fr; } }
</style>
