---
interface Props {
  id: string;
  name: string;
  category: string;
  summary: string;
  useCases: string[];
  suitableCustomers: string[];
  processing: string[];
  specs: Array<{ label: string; value: string }>;
  concerns: string[];
  inquiryNeeds: string[];
  index?: number;
}

const {
  id,
  name,
  category,
  summary,
  useCases,
  suitableCustomers,
  processing,
  specs,
  concerns,
  inquiryNeeds,
  index = 0,
} = Astro.props;
const phoneNumber = '13450853338';
---
<article class="product-detail" id={id} style={`--pd-i:${index}`}>
  <header class="product-detail-header">
    <div class="product-detail-meta">
      <span class="product-detail-no">{String(index + 1).padStart(2, '0')}</span>
      <span class="product-detail-cat">{category}</span>
    </div>
    <h3 class="product-detail-name">{name}</h3>
    <p class="product-detail-summary">{summary}</p>
  </header>

  <div class="product-detail-grid">
    <div class="product-detail-block">
      <h4>
        <span class="block-icon">◆</span>
        主要用途
      </h4>
      <ul>{useCases.map((u) => <li>{u}</li>)}</ul>
    </div>

    <div class="product-detail-block">
      <h4>
        <span class="block-icon">◆</span>
        适合客户
      </h4>
      <ul>{suitableCustomers.map((u) => <li>{u}</li>)}</ul>
    </div>

    <div class="product-detail-block">
      <h4>
        <span class="block-icon">◆</span>
        加工方式
      </h4>
      <ul>{processing.map((u) => <li>{u}</li>)}</ul>
    </div>

    <div class="product-detail-block">
      <h4>
        <span class="block-icon">◆</span>
        常见关注指标
      </h4>
      <ul>{concerns.map((u) => <li>{u}</li>)}</ul>
    </div>
  </div>

  <div class="product-detail-specs">
    <h4>典型规格范围（参考）</h4>
    <table class="table">
      <tbody>
        {specs.map((s) => (
          <tr>
            <th>{s.label}</th>
            <td>{s.value}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="specs-note">* 实际规格以双方沟通确认的技术单为准，可按客户要求调整。</p>
  </div>

  <div class="product-detail-inquiry">
    <div class="inquiry-content">
      <h4>询价需提供</h4>
      <ol>{inquiryNeeds.map((u) => <li>{u}</li>)}</ol>
    </div>
    <a href={`tel:${phoneNumber}`} class="btn btn-phone product-cta">
      <span>立即咨询</span>
      <span class="cta-phone">{phoneNumber}</span>
    </a>
  </div>
</article>

<style>
  .product-detail {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-primary);
    border-radius: var(--radius-md);
    padding: var(--sp-6) var(--sp-6);
    margin-bottom: var(--sp-6);
    scroll-margin-top: 100px;
    transition: box-shadow 0.28s var(--ease-out), border-color 0.28s var(--ease-out);
  }

  .product-detail:hover {
    box-shadow: var(--shadow-md);
    border-left-color: var(--color-accent);
  }

  .product-detail-header {
    border-bottom: 1px dashed var(--color-border);
    padding-bottom: var(--sp-4);
    margin-bottom: var(--sp-5);
  }

  .product-detail-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }

  .product-detail-no {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 700;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    letter-spacing: 0.05em;
  }

  .product-detail-cat {
    font-size: var(--fs-xs);
    color: var(--color-primary);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .product-detail-name {
    font-size: var(--fs-xl);
    color: var(--color-primary-dark);
    margin-bottom: var(--sp-3);
  }

  .product-detail-summary {
    font-size: var(--fs-base);
    color: var(--color-text-soft);
    margin: 0;
    line-height: 1.75;
  }

  .product-detail-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-5);
    margin-bottom: var(--sp-5);
  }

  .product-detail-block h4 {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-base);
    color: var(--color-primary-dark);
    margin-bottom: var(--sp-3);
    font-weight: 700;
  }

  .block-icon {
    color: var(--color-accent);
    font-size: 12px;
  }

  .product-detail-block ul {
    margin: 0;
    padding-left: 1.2em;
    color: var(--color-text-soft);
    font-size: var(--fs-sm);
    line-height: 1.85;
  }

  .product-detail-block li {
    margin-bottom: 4px;
  }

  .product-detail-specs {
    margin-bottom: var(--sp-5);
    background: var(--color-surface-alt);
    padding: var(--sp-5);
    border-radius: var(--radius-md);
  }

  .product-detail-specs h4 {
    font-size: var(--fs-base);
    color: var(--color-primary-dark);
    margin-bottom: var(--sp-3);
    font-weight: 700;
  }

  .product-detail-specs th {
    width: 30%;
    background: var(--color-surface);
  }

  .specs-note {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    margin: var(--sp-3) 0 0;
    font-style: italic;
  }

  .product-detail-inquiry {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-5);
    background: linear-gradient(135deg, var(--color-primary-soft) 0%, #f7fbf8 100%);
    padding: var(--sp-5);
    border-radius: var(--radius-md);
    border: 1px solid #d3e2d8;
  }

  .inquiry-content h4 {
    font-size: var(--fs-base);
    color: var(--color-primary-dark);
    margin-bottom: var(--sp-3);
    font-weight: 700;
  }

  .inquiry-content ol {
    margin: 0;
    padding-left: 1.5em;
    color: var(--color-text-soft);
    font-size: var(--fs-sm);
    line-height: 1.85;
  }

  .inquiry-content li {
    margin-bottom: 2px;
  }

  .product-cta {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.2;
    padding: 14px 22px;
  }

  .cta-phone {
    font-size: 13px;
    opacity: 0.9;
    font-weight: 600;
    margin-top: 2px;
    font-feature-settings: 'tnum';
  }

  @media (max-width: 720px) {
    .product-detail {
      padding: var(--sp-4);
    }

    .product-detail-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-4);
    }

    .product-detail-inquiry {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
    }

    .inquiry-content ol {
      text-align: left;
    }
  }
</style>