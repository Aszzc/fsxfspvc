---
interface Props {
  id?: string;
  name: string;
  category: string;
  description: string;
  highlights?: string[];
  href?: string;
  icon?: string;
  index?: number;
}

const { id, name, category, description, highlights = [], href = '/products/', icon = '◆', index = 0 } = Astro.props;
---
<a href={href} class="product-card" id={id} style={`--card-i:${index}`}>
  <div class="product-card-top">
    <div class="product-card-icon" aria-hidden="true">{icon}</div>
    <div class="product-card-category">{category}</div>
  </div>
  <h3 class="product-card-name">{name}</h3>
  <p class="product-card-desc">{description}</p>
  {highlights.length > 0 && (
    <ul class="product-card-list">
      {highlights.map((h) => (
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check-icon" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>{h}</span>
        </li>
      ))}
    </ul>
  )}
  <span class="product-card-link">
    查看规格
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="arrow-icon" aria-hidden="true">
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </span>
</a>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-5);
    text-decoration: none;
    color: inherit;
    transition: all 0.28s var(--ease-out);
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .product-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-accent) 100%);
    transition: width 0.35s var(--ease-out);
  }

  .product-card:hover {
    border-color: transparent;
    box-shadow: var(--shadow-md);
    text-decoration: none;
    color: inherit;
    transform: translateY(-4px);
  }

  .product-card:hover::before {
    width: 100%;
  }

  .product-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-4);
  }

  .product-card-icon {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-soft);
    color: var(--color-primary);
    border-radius: var(--radius-sm);
    font-size: 22px;
    font-weight: 700;
    transition: all 0.28s var(--ease-out);
  }

  .product-card:hover .product-card-icon {
    background: var(--color-accent);
    color: #fff;
    transform: rotate(-6deg) scale(1.05);
  }

  .product-card-category {
    font-size: var(--fs-xs);
    color: var(--color-accent-dark);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    background: var(--color-accent-soft);
    border-radius: 999px;
  }

  .product-card-name {
    font-size: var(--fs-lg);
    margin-bottom: var(--sp-3);
    color: var(--color-primary-dark);
  }

  .product-card-desc {
    font-size: var(--fs-sm);
    color: var(--color-text-soft);
    line-height: 1.7;
    margin-bottom: var(--sp-4);
  }

  .product-card-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--sp-5);
    font-size: var(--fs-sm);
    color: var(--color-text-soft);
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .product-card-list li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .check-icon {
    width: 14px;
    height: 14px;
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .product-card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-primary);
    font-size: var(--fs-sm);
    font-weight: 600;
    margin-top: auto;
    padding-top: var(--sp-3);
    border-top: 1px dashed var(--color-border);
    transition: color 0.18s var(--ease-out);
  }

  .product-card:hover .product-card-link {
    color: var(--color-accent);
  }

  .arrow-icon {
    width: 14px;
    height: 14px;
    transition: transform 0.2s var(--ease-out);
  }

  .product-card:hover .arrow-icon {
    transform: translateX(4px);
  }
</style>