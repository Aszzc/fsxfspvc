---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import SectionTitle from '../components/SectionTitle.astro';

const phoneNumber = '13450853338';

const products = [
  {
    id: 'insulation-70',
    name: '70°C 绝缘料',
    category: 'PVC 绝缘',
    icon: '70',
    description: '适用于 BV、BVR、BVV 等常规电线导体绝缘层，配方成熟，挤出稳定。',
    highlights: ['工作温度 70°C', '电气绝缘稳定', '阻燃等级可调'],
  },
  {
    id: 'sheath',
    name: 'PVC 护套料',
    category: '外护套',
    icon: 'SH',
    description: '用于电线电缆外护套，兼顾柔韧、耐磨和耐候表现，适配多类线缆结构。',
    highlights: ['柔韧性好', '耐磨耐候', '颜色可定制'],
  },
  {
    id: 'electronic',
    name: '电子线料',
    category: '电子线材',
    icon: 'EL',
    description: '面向 USB 线、信号线、DC 线等小线径线材，关注低气味与高速挤出稳定性。',
    highlights: ['低气味配方', '高速挤出', '批次色差可控'],
  },
  {
    id: 'plug',
    name: '插头注塑料',
    category: '电源插头',
    icon: 'PL',
    description: '适用于电源插头、插座外壳和电气附件，强度高、流动性好、易成型。',
    highlights: ['硬度可调', '阻燃可定制', '注塑成型稳定'],
  },
  {
    id: 'heat-resistant-105',
    name: '105°C 耐温料',
    category: '耐高温',
    icon: '105',
    description: '用于家电内部线、变压器引线、灯具线等高温场景，兼顾老化稳定性。',
    highlights: ['耐温 105°C', '老化性能稳定', '可做 UL 等级'],
  },
  {
    id: 'modified',
    name: '改性 PVC 定制料',
    category: '定制配方',
    icon: 'RD',
    description: '按客户样品、图纸和指标调整硬度、阻燃、耐寒、透明度、雾面效果等性能。',
    highlights: ['来样开发', '小批试样', '长期配方管理'],
  },
];

const processSteps = [
  ['01', '需求确认', '用途、标准、颜色、月用量与加工设备'],
  ['02', '配方设计', '根据性能目标调整树脂、增塑、阻燃和稳定体系'],
  ['03', '小样试制', '小批量造粒，客户上机验证挤出或注塑表现'],
  ['04', '批量生产', '混料、塑化、挤出、冷却、筛分和包装'],
  ['05', '留样追溯', '每批次记录配方、外观、粒型和关键指标'],
];

const qualityItems = [
  '原料渠道固定，关键助剂批次可追踪',
  '按客户工艺窗口控制塑化、流动和粒型一致性',
  '支持颜色、硬度、阻燃、耐寒、耐温等指标定制',
  '试样到量产保留配方记录，减少后续换批波动',
];

const customers = ['电线电缆厂', '电子线材厂', '电源插头厂', '家电制造厂', 'LED 灯带厂', '设备线束厂'];

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '佛山市三水湘发顺塑料有限公司',
  alternateName: '湘发顺塑料',
  url: 'https://xfspvc.com/',
  telephone: '+86-13450853338',
  address: {
    '@type': 'PostalAddress',
    addressRegion: '广东省',
    addressLocality: '佛山市三水区',
    addressCountry: 'CN',
  },
};
---

<BaseLayout
  title="佛山 PVC 电线电缆料生产厂家"
  description="佛山市三水湘发顺塑料有限公司是广东佛山 PVC 电线电缆料生产厂家，提供 70°C 绝缘料、护套料、电子线料、插头料、105°C 耐温料、耐寒料、透明料及改性 PVC 定制配方。"
  jsonLd={organizationLd}
>
  <section class="hero">
    <img class="hero-media" src="/images/manufacturing-hero.png" alt="PVC 电线电缆料造粒生产线" loading="eager" />
    <div class="hero-shade" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <div class="hero-kicker">佛山工厂直供 · PVC 线缆料定制配方</div>
        <h1>为电线电缆企业提供稳定的 PVC 改性料</h1>
        <p>
          自有配方研发与造粒产线，覆盖绝缘料、护套料、电子线料、插头料、耐温耐寒与透明雾面系列。按用途、标准、加工设备和成本目标匹配配方。
        </p>
        <div class="hero-actions">
          <a class="btn btn-phone btn-lg" href={`tel:${phoneNumber}`}>电话 / 微信 {phoneNumber}</a>
          <a class="btn btn-light btn-lg" href="/products/">查看产品目录</a>
        </div>
      </div>
      <div class="hero-panel" aria-label="核心制造能力">
        <div><strong>9+</strong><span>产品品类</span></div>
        <div><strong>3-7 天</strong><span>常规试样</span></div>
        <div><strong>500kg</strong><span>常规起订</span></div>
      </div>
    </div>
  </section>

  <section class="capability-strip">
    <div class="container strip-grid">
      <span>自有配方研发</span>
      <span>混料挤出造粒</span>
      <span>批次留样追溯</span>
      <span>来样来图定制</span>
      <span>可来厂看产线</span>
    </div>
  </section>

  <section class="section">
    <div class="container split-intro">
      <div>
        <p class="section-eyebrow">MANUFACTURING PARTNER</p>
        <h2>不是卖通用料，而是帮你把线材工艺跑稳</h2>
      </div>
      <p>
        线缆料的关键不只在指标表，还在客户设备上的挤出速度、表面状态、色差、气味、韧性和长期供货一致性。湘发顺以“试样验证 + 配方管理 + 批次追溯”的方式服务制造客户。
      </p>
    </div>
    <div class="container feature-grid">
      <article>
        <span>01</span>
        <h3>按应用场景开发</h3>
        <p>从建筑线、电子线、电源线到户外耐寒线，围绕成品结构和加工窗口确定配方。</p>
      </article>
      <article>
        <span>02</span>
        <h3>小样先验证</h3>
        <p>新客户、新颜色、新性能先做试样，上机确认后再进入批量供货，降低试错成本。</p>
      </article>
      <article>
        <span>03</span>
        <h3>长期稳定供货</h3>
        <p>固定关键原料渠道，保留配方与批次记录，帮助长期客户减少换批波动。</p>
      </article>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <SectionTitle
        eyebrow="PRODUCTS"
        title="核心 PVC 电线电缆料"
        subtitle="覆盖常规线缆、电子线、插头注塑和特殊性能定制，支持颜色、硬度、阻燃、耐温、耐寒等方向调整。"
      />
      <div class="grid grid-3">
        {products.map((product, index) => (
          <ProductCard {...product} href={`/products/#${product.id}`} index={index} />
        ))}
      </div>
    </div>
  </section>

  <section class="section process-section">
    <div class="container process-layout">
      <div class="process-copy">
        <p class="section-eyebrow">PROCESS</p>
        <h2>从配方到交付，每一步围绕量产稳定</h2>
        <p>制造型客户关心的是材料在自己设备上的表现。我们把需求沟通、试样验证、批量生产和留样追溯串成闭环，减少后续沟通成本。</p>
        <a class="btn btn-outline" href="/manufacturing/">查看制造能力</a>
      </div>
      <div class="process-list">
        {processSteps.map(([no, title, desc]) => (
          <article>
            <strong>{no}</strong>
            <div>
              <h3>{title}</h3>
              <p>{desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section quality-section">
    <div class="container quality-grid">
      <div class="quality-card">
        <p class="section-eyebrow">QUALITY CONTROL</p>
        <h2>质量控制关注可生产、可追溯、可复购</h2>
        <ul>
          {qualityItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="customer-card">
        <h3>适合这些客户</h3>
        <div class="customer-tags">
          {customers.map((customer) => <span>{customer}</span>)}
        </div>
        <p>如果你有样品、图纸、指标表或当前材料痛点，可以直接沟通，我们按目标用途给出试样建议。</p>
      </div>
    </div>
  </section>

  <section class="section inquiry-section">
    <div class="container inquiry-box">
      <div>
        <p class="section-eyebrow">GET QUOTE</p>
        <h2>需要试样或报价？</h2>
        <p>请提供用途、规格、颜色、阻燃/耐温/耐寒要求、预计月用量和加工方式。我们会按需求评估配方、试样和报价。</p>
      </div>
      <div class="inquiry-actions">
        <a class="btn btn-phone btn-lg" href={`tel:${phoneNumber}`}>电话 / 微信 {phoneNumber}</a>
        <a class="btn btn-light btn-lg" href="/contact/">查看联系方式</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 720px;
    display: grid;
    align-items: end;
    overflow: hidden;
    background: #101820;
  }

  .hero-media,
  .hero-shade {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-media {
    object-fit: cover;
  }

  .hero-shade {
    background:
      linear-gradient(90deg, rgba(8, 16, 22, 0.92) 0%, rgba(8, 16, 22, 0.72) 38%, rgba(8, 16, 22, 0.18) 78%),
      linear-gradient(0deg, rgba(8, 16, 22, 0.72), transparent 46%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 680px) minmax(280px, 360px);
    gap: var(--sp-7);
    align-items: end;
    padding-top: 180px;
    padding-bottom: var(--sp-8);
  }

  .hero-kicker {
    color: #f2a65a;
    font-weight: 700;
    letter-spacing: 0.12em;
    font-size: 13px;
    text-transform: uppercase;
    margin-bottom: var(--sp-4);
  }

  .hero h1 {
    color: #fff;
    font-size: clamp(42px, 6vw, 76px);
    line-height: 1.05;
    max-width: 760px;
    margin-bottom: var(--sp-5);
  }

  .hero p {
    color: rgba(255, 255, 255, 0.84);
    font-size: 19px;
    max-width: 640px;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
    margin-top: var(--sp-6);
  }

  .hero-panel {
    display: grid;
    gap: 1px;
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(14px);
  }

  .hero-panel div {
    padding: var(--sp-5);
    background: rgba(7, 18, 24, 0.58);
  }

  .hero-panel strong {
    display: block;
    color: #fff;
    font-size: 32px;
    line-height: 1;
    margin-bottom: 8px;
  }

  .hero-panel span {
    color: rgba(255, 255, 255, 0.74);
    font-size: 14px;
  }

  .capability-strip {
    background: #f0f4f2;
    border-bottom: 1px solid var(--color-border);
  }

  .strip-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
  }

  .strip-grid span {
    padding: 18px 16px;
    text-align: center;
    font-weight: 700;
    color: var(--color-primary-dark);
    border-left: 1px solid var(--color-border);
  }

  .strip-grid span:last-child {
    border-right: 1px solid var(--color-border);
  }

  .split-intro {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: var(--sp-8);
    align-items: start;
    margin-bottom: var(--sp-7);
  }

  .split-intro h2,
  .process-copy h2,
  .quality-card h2,
  .inquiry-box h2 {
    font-size: clamp(30px, 4vw, 48px);
    color: var(--color-primary-dark);
  }

  .split-intro > p,
  .process-copy > p {
    font-size: 18px;
    color: var(--color-text-soft);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5);
  }

  .feature-grid article,
  .quality-card,
  .customer-card,
  .process-list article {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .feature-grid article {
    padding: var(--sp-6);
  }

  .feature-grid span {
    color: var(--color-accent);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.16em;
  }

  .feature-grid h3 {
    color: var(--color-primary-dark);
    margin-top: var(--sp-3);
  }

  .process-layout,
  .quality-grid,
  .inquiry-box {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--sp-7);
    align-items: center;
  }

  .process-list {
    display: grid;
    gap: var(--sp-3);
  }

  .process-list article {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--sp-4);
    padding: var(--sp-5);
  }

  .process-list strong {
    color: var(--color-accent);
    font-size: 28px;
    line-height: 1;
  }

  .process-list h3 {
    color: var(--color-primary-dark);
    margin-bottom: 4px;
  }

  .process-list p {
    margin: 0;
    color: var(--color-text-soft);
  }

  .quality-section {
    background: #15231f;
  }

  .quality-card,
  .customer-card {
    padding: var(--sp-7);
  }

  .quality-card h2,
  .quality-card li,
  .customer-card h3,
  .customer-card p {
    color: #fff;
  }

  .quality-card,
  .customer-card {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .quality-card ul {
    list-style: none;
    padding: 0;
    margin: var(--sp-5) 0 0;
    display: grid;
    gap: var(--sp-3);
  }

  .quality-card li {
    padding-left: 24px;
    position: relative;
  }

  .quality-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    width: 9px;
    height: 9px;
    background: var(--color-accent);
  }

  .customer-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: var(--sp-5) 0;
  }

  .customer-tags span {
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.88);
    font-weight: 700;
    font-size: 14px;
  }

  .inquiry-section {
    padding-bottom: var(--sp-9);
  }

  .inquiry-box {
    padding: var(--sp-7);
    background: linear-gradient(135deg, #0f3a32, #09231e);
  }

  .inquiry-box h2,
  .inquiry-box p {
    color: #fff;
  }

  .inquiry-actions {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  @media (max-width: 900px) {
    .hero {
      min-height: 650px;
    }

    .hero-inner,
    .split-intro,
    .process-layout,
    .quality-grid,
    .inquiry-box {
      grid-template-columns: 1fr;
    }

    .hero-inner {
      padding-top: 120px;
    }

    .strip-grid,
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .strip-grid span {
      border-right: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>
