---
interface Props {
  locale?: 'zh-CN' | 'en';
  brandShort?: string;
}

const { locale = 'zh-CN', brandShort = '湘发顺塑料' } = Astro.props;
const isEn = locale === 'en';
const phoneNumber = '13450853338';

const navItems = isEn
  ? [
      { href: '/en/', label: 'Home' },
      { href: '/en/products/', label: 'Products' },
      { href: '/en/manufacturing/', label: 'Manufacturing' },
      { href: '/en/about/', label: 'About' },
      { href: '/en/contact/', label: 'Contact' },
    ]
  : [
      { href: '/', label: '首页' },
      { href: '/products/', label: '产品目录' },
      { href: '/manufacturing/', label: '制造能力' },
      { href: '/about/', label: '关于我们' },
      { href: '/contact/', label: '联系我们' },
    ];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const altPath = currentPath.startsWith('/en')
  ? (currentPath === '/en' ? '/' : currentPath.replace(/^\/en/, '') || '/')
  : (currentPath === '/' ? '/en/' : '/en' + currentPath);
const altLabel = isEn ? '中文' : 'EN';
---

<header class="site-header">
  <div class="header-top">
    <div class="container header-top-inner">
      <span>{isEn ? 'Foshan PVC wire and cable compound manufacturer' : '佛山 PVC 电线电缆料生产厂家 · 自有配方 · 工厂直供'}</span>
      <a href={`tel:${phoneNumber}`}>电话 / 微信 {phoneNumber}</a>
    </div>
  </div>
  <div class="header-main">
    <div class="container header-main-inner">
      <a class="brand" href={isEn ? '/en/' : '/'} aria-label={isEn ? 'Xiangfa Shun Home' : '湘发顺塑料首页'}>
        <span class="brand-name">{isEn ? 'Xiangfa Shun' : brandShort}</span>
        <span class="brand-sub">{isEn ? 'PVC Wire & Cable Compound' : 'PVC 电线电缆料 · 改性配方'}</span>
      </a>
      <nav class="primary-nav" aria-label="Primary navigation">
        {navItems.map((item) => {
          const itemPath = item.href.replace(/\/$/, '') || '/';
          const isActive = currentPath === itemPath;
          return <a href={item.href} class={isActive ? 'is-active' : ''}>{item.label}</a>;
        })}
      </nav>
      <div class="header-actions">
        <a class="lang-switch" href={altPath}>{altLabel}</a>
        <a class="btn btn-phone" href={isEn ? '/en/tools/inquiry/' : '/tools/inquiry/'}>{isEn ? 'Get Quote' : '立即询价'}</a>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-top {
    background: var(--color-primary-dark);
    color: rgba(255, 255, 255, 0.86);
    font-size: 12px;
  }

  .header-top-inner,
  .header-main-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
  }

  .header-top-inner {
    padding-top: 7px;
    padding-bottom: 7px;
  }

  .header-top a {
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }

  .header-main-inner {
    padding-top: 16px;
    padding-bottom: 16px;
  }

  .brand {
    display: grid;
    gap: 3px;
    color: var(--color-primary-dark);
    text-decoration: none;
    min-width: 190px;
  }

  .brand:hover {
    color: var(--color-primary-dark);
    text-decoration: none;
  }

  .brand-name {
    font-size: 24px;
    line-height: 1;
    font-weight: 900;
    letter-spacing: 0.04em;
  }

  .brand-sub {
    color: var(--color-text-muted);
    font-size: 12px;
    font-weight: 700;
  }

  .primary-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex: 1;
  }

  .primary-nav a,
  .lang-switch {
    color: var(--color-text);
    padding: 9px 13px;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
  }

  .primary-nav a:hover,
  .primary-nav a.is-active {
    background: var(--color-primary-soft);
    color: var(--color-primary-dark);
    text-decoration: none;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .lang-switch {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  @media (max-width: 980px) {
    .header-top-inner {
      justify-content: center;
      text-align: center;
      flex-wrap: wrap;
    }

    .header-main-inner {
      flex-wrap: wrap;
    }

    .primary-nav {
      order: 3;
      flex-basis: 100%;
      overflow-x: auto;
      justify-content: flex-start;
      padding-bottom: 2px;
    }

    .brand-sub {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .header-actions .btn {
      display: none;
    }
  }
</style>
