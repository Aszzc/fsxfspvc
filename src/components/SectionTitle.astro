---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
  id?: string;
}

const { title, subtitle, align = 'center', id } = Astro.props;
---
<div class={`section-heading section-heading-${align}`} id={id}>
  <div class="section-divider"></div>
  <h2 class="section-title">{title}</h2>
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
</div>

<style>
  .section-heading {
    margin-bottom: var(--sp-6);
  }

  .section-heading-left {
    text-align: left;
  }

  .section-heading-left .section-divider {
    margin-left: 0;
  }

  .section-heading-left .section-subtitle {
    text-align: left;
  }
</style>