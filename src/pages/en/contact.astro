---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';

const phoneNumber = '13450853338';

const contactMethods = [
  { icon: '📞', title: 'Phone / SMS', primary: phoneNumber, href: `tel:${phoneNumber}`, desc: 'Call directly during business hours for technical and procurement questions.' },
  { icon: '💬', title: 'WeChat (same number)', primary: phoneNumber, href: `weixin://`, desc: 'Same number as phone. Add us to send text, photos, files, video, voice.' },
  { icon: '📕', title: 'Xiaohongshu', primary: 'Search "Xiangfa Shun Plastic"', href: 'https://www.xiaohongshu.com/', desc: 'Follow our account to see factory daily, product photos and customer cases.' },
  { icon: '🎵', title: 'Douyin', primary: 'Search "Xiangfa Shun Plastic"', href: 'https://www.douyin.com/', desc: 'Follow our account to see production process and workshop footage.' },
];

const inquiryList = [
  'Company name / contact / contact info',
  'Usage scenario (e.g., building wire, power cord jacket, electronic wire, outdoor wiring…)',
  'Wire spec (conductor cross-section, insulation thickness, sheath thickness)',
  'Key performance requirements (temp / flame retardant / cold-resistant / hardness / color / transparency)',
  'Applicable standard (GB / UL / VDE / other)',
  'Estimated monthly / annual volume',
  'Processing method (extrusion speed, die specs)',
  'Other special requirements (odor, anti-yellowing, ROHS / REACH, etc.)',
];
---
<BaseLayout
  title="Contact Us"
  description="Contact Foshan Xiangfa Shun Plastic Co., Ltd.: Tel/WeChat 13450853338, Xiaohongshu / Douyin search 'Xiangfa Shun Plastic'. Located in Sanshui District, Foshan, China. Inquiry requires usage scenario, performance requirements, specs and volume."
  locale="en"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact Foshan Xiangfa Shun Plastic Co., Ltd.',
    description: 'Foshan PVC wire & cable compound manufacturer contact info',
    mainEntity: {
      '@type': 'LocalBusiness',
      name: 'Foshan Xiangfa Shun Plastic Co., Ltd.',
      telephone: '+86-13450853338',
      url: 'https://xfspvc.com/en/',
      address: {
        '@type': 'PostalAddress',
        addressRegion: 'Guangdong',
        addressLocality: 'Sanshui District, Foshan',
        addressCountry: 'CN',
      },
    },
  }}
>
  <section class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href="/en/">Home</a> / Contact</div>
      <h1>Contact Us</h1>
      <p class="page-header-sub">
        WeChat / phone same number. Text, photos, files, video and voice all welcome.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        {contactMethods.map((m) => (
          <a href={m.href} class="contact-card">
            <div class="contact-icon">{m.icon}</div>
            <h3 class="contact-title">{m.title}</h3>
            <div class="contact-primary">{m.primary}</div>
            <p class="contact-desc">{m.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="qr-block">
        <div class="qr-card">
          <div class="qr-placeholder">
            <span>WeChat QR</span>
            <small>Replace with real QR: public/images/wechat-qr.jpg</small>
          </div>
          <h3>Scan to add WeChat</h3>
          <p>Same as phone: 13450853338</p>
        </div>

        <div class="info-card">
          <h3>Factory Address / Business Hours</h3>
          <ul class="info-list">
            <li><strong>Factory:</strong><span>Sanshui District, Foshan, Guangdong, China</span></li>
            <li><strong>Hours:</strong><span>Mon - Sat 8:00 - 18:00</span></li>
            <li><strong>Tel / WeChat:</strong><span><a href={`tel:${phoneNumber}`}>{phoneNumber}</a></span></li>
            <li><strong>Visit factory:</strong><span>Please call ahead to schedule.</span></li>
          </ul>
          <div class="info-cta">
            <a href={`tel:${phoneNumber}`} class="btn btn-phone btn-lg">📞 Contact Now</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionTitle title="Information Needed Before Inquiry" subtitle="The more complete the info, the more efficient communication and accurate quote" />

      <div class="inquiry-list-box">
        <ol class="inquiry-checklist">
          {inquiryList.map((item) => <li>{item}</li>)}
        </ol>

        <div class="inquiry-tip">
          <h4>Tips</h4>
          <ul>
            <li>If you have wire samples, send photos or samples to us — easier to assess the formula.</li>
            <li>If you have applicable standard documents (GB / UL / VDE, etc.), send them together.</li>
            <li>For color requirements, provide color card or Pantone number to avoid color description deviation.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header { background: var(--color-surface-alt); padding: var(--sp-6) 0 var(--sp-5); border-bottom: 1px solid var(--color-border); }
  .breadcrumb { font-size: var(--fs-sm); color: var(--color-text-muted); margin-bottom: var(--sp-3); }
  .breadcrumb a { color: var(--color-text-muted); }
  .page-header h1 { font-size: var(--fs-2xl); margin-bottom: var(--sp-2); color: var(--color-primary-dark); }
  .page-header-sub { color: var(--color-text-soft); margin: 0; }
  .section-alt { background: var(--color-surface-alt); }

  .contact-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--sp-4); }
  .contact-card { display: block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: var(--sp-5); text-align: center; text-decoration: none; color: inherit; transition: all 0.15s ease; }
  .contact-card:hover { border-color: var(--color-primary); box-shadow: 0 4px 12px rgba(31, 77, 58, 0.08); text-decoration: none; color: inherit; transform: translateY(-2px); }
  .contact-icon { font-size: 32px; margin-bottom: var(--sp-3); }
  .contact-title { font-size: var(--fs-md); color: var(--color-primary-dark); margin-bottom: var(--sp-2); }
  .contact-primary { font-size: var(--fs-md); color: var(--color-primary); font-weight: 600; margin-bottom: var(--sp-3); }
  .contact-desc { font-size: var(--fs-sm); color: var(--color-text-soft); margin: 0; line-height: 1.65; }

  .qr-block { display: grid; grid-template-columns: 1fr 1.4fr; gap: var(--sp-6); align-items: stretch; }
  .qr-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: var(--sp-5); text-align: center; display: flex; flex-direction: column; align-items: center; }
  .qr-placeholder { width: 200px; height: 200px; background: repeating-linear-gradient(45deg, #2a2a26, #2a2a26 8px, #fff 8px, #fff 16px); border: 1px solid var(--color-border); margin-bottom: var(--sp-4); display: flex; flex-direction: column; align-items: center; justify-content: center; color: #fff; font-weight: 600; font-size: var(--fs-sm); text-align: center; padding: var(--sp-3); text-shadow: 0 1px 3px rgba(0,0,0,0.6); }
  .qr-placeholder small { display: block; margin-top: var(--sp-2); font-size: 10px; font-weight: 400; opacity: 0.9; }
  .qr-card h3 { color: var(--color-primary-dark); margin-bottom: var(--sp-2); }
  .qr-card p { color: var(--color-text-soft); font-size: var(--fs-sm); margin: 0; }

  .info-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: var(--sp-6); }
  .info-card h3 { color: var(--color-primary-dark); margin-bottom: var(--sp-4); padding-bottom: var(--sp-3); border-bottom: 1px solid var(--color-border); }
  .info-list { list-style: none; padding: 0; margin: 0 0 var(--sp-5); }
  .info-list li { display: flex; padding: var(--sp-3) 0; border-bottom: 1px dashed var(--color-border); font-size: var(--fs-sm); color: var(--color-text-soft); }
  .info-list li:last-child { border-bottom: none; }
  .info-list strong { width: 130px; color: var(--color-text); font-weight: 600; flex-shrink: 0; }
  .info-cta { text-align: center; }
  .btn-lg { padding: 14px 26px; font-size: 17px; }

  .inquiry-list-box { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: var(--sp-6); }
  .inquiry-checklist { columns: 2; column-gap: var(--sp-6); margin: 0 0 var(--sp-5); padding-left: 1.5em; }
  .inquiry-checklist li { margin-bottom: var(--sp-3); color: var(--color-text-soft); line-height: 1.7; break-inside: avoid; }
  .inquiry-tip { background: var(--color-surface-alt); border-left: 3px solid var(--color-accent); padding: var(--sp-4) var(--sp-5); border-radius: 3px; margin-top: var(--sp-4); }
  .inquiry-tip h4 { color: var(--color-primary-dark); margin-bottom: var(--sp-3); font-size: var(--fs-base); }
  .inquiry-tip ul { margin: 0; color: var(--color-text-soft); font-size: var(--fs-sm); }
  .inquiry-tip li { margin-bottom: 4px; }

  @media (max-width: 1000px) { .contact-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 720px) {
    .contact-grid, .qr-block { grid-template-columns: 1fr; }
    .inquiry-checklist { columns: 1; }
    .info-list strong { width: 110px; }
  }
</style>