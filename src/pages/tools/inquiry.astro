---
import BaseLayout from '../../layouts/BaseLayout.astro'; import { siteConfig } from '../../config/site'; import { products } from '../../data/products';
---
<BaseLayout title="在线询价" description="提交 PVC 电线电缆料用途、规格、性能、标准和用量信息，生成完整询价邮件。" breadcrumbs={[{name:'首页',href:'/'},{name:'在线询价',href:'/tools/inquiry/'}]}><section class="page-header"><div class="container"><div class="section-eyebrow page-eyebrow">INQUIRY</div><h1>在线询价</h1><p class="page-header-sub">无需注册。填写后会在您的邮件客户端中生成询价内容，信息由您确认后发送。</p></div></section><section class="section"><div class="container form-wrap"><form id="inquiry-form"><label>产品<select name="product" required><option value="">请选择</option>{products.zh.map(p=><option value={p.name} data-slug={p.slug}>{p.name}</option>)}</select></label><label>公司 / 联系人<input name="contact" autocomplete="organization" required /></label><label>联系电话或邮箱<input name="reply" autocomplete="email" required /></label><label>使用场景与线缆规格<textarea name="application" rows="4" required></textarea></label><label>性能、标准、颜色及预计用量<textarea name="requirements" rows="5" required></textarea></label><button class="btn btn-primary" type="submit">生成询价邮件</button><p class="form-note">收件邮箱：<a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>　电话/微信：<a href={`tel:${siteConfig.phone}`}>{siteConfig.phone}</a></p></form></div></section><script define:vars={{email:siteConfig.email}}>const form=document.querySelector('#inquiry-form');const params=new URLSearchParams(location.search);const wanted=params.get('product');if(wanted){const option=form?.querySelector(`option[data-slug="${CSS.escape(wanted)}"]`);if(option) option.selected=true;}form?.addEventListener('submit',(event)=>{event.preventDefault();const data=new FormData(form);const subject=`PVC材料询价 - ${data.get('product')}`;const body=`产品：${data.get('product')}\n公司/联系人：${data.get('contact')}\n回复方式：${data.get('reply')}\n\n使用场景与规格：\n${data.get('application')}\n\n性能、标准、颜色及用量：\n${data.get('requirements')}`;location.href=`mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;});</script></BaseLayout><style>.page-eyebrow{margin-bottom:var(--sp-3)}.form-wrap{max-width:760px}.form-wrap form{display:grid;gap:var(--sp-5);padding:var(--sp-7);border:1px solid var(--color-border);border-radius:var(--radius-md);box-shadow:var(--shadow-xs)}label{display:grid;gap:8px;font-weight:700;color:var(--color-primary-dark)}input,select,textarea{width:100%;padding:12px 14px;border:1px solid var(--color-border-strong);border-radius:var(--radius-sm);font:inherit;background:#fff}textarea{resize:vertical}.form-note{font-size:var(--fs-sm);margin:0;color:var(--color-text-soft)}@media(max-width:720px){.form-wrap form{padding:var(--sp-5)}}</style>

