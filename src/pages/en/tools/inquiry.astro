---
import BaseLayout from '../../../layouts/BaseLayout.astro'; import { siteConfig } from '../../../config/site'; import { products } from '../../../data/products';
---
<BaseLayout locale="en" title="Online Inquiry" description="Share your PVC cable compound application, specification, performance, standard and volume requirements in a structured email." breadcrumbs={[{name:'Home',href:'/en/'},{name:'Online Inquiry',href:'/en/tools/inquiry/'}]}><section class="page-header"><div class="container"><div class="section-eyebrow page-eyebrow">INQUIRY</div><h1>Online Inquiry</h1><p class="page-header-sub">No account required. Your details are prepared in your email app for your review before sending.</p></div></section><section class="section"><div class="container form-wrap"><form id="inquiry-form"><label>Product<select name="product" required><option value="">Select a product</option>{products.en.map(p=><option value={p.name} data-slug={p.slug}>{p.name}</option>)}</select></label><label>Company / Contact<input name="contact" autocomplete="organization" required /></label><label>Email or phone<input name="reply" autocomplete="email" required /></label><label>Application and cable specification<textarea name="application" rows="4" required></textarea></label><label>Performance, standard, color and volume<textarea name="requirements" rows="5" required></textarea></label><button class="btn btn-primary" type="submit">Prepare inquiry email</button><p class="form-note">Email: <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a> · Phone/WeChat: <a href={`tel:${siteConfig.phoneInternational}`}>{siteConfig.phoneInternational}</a></p></form></div></section><script define:vars={{email:siteConfig.email}}>const form=document.querySelector('#inquiry-form');const params=new URLSearchParams(location.search);const wanted=params.get('product');if(wanted){const option=form?.querySelector(`option[data-slug="${CSS.escape(wanted)}"]`);if(option) option.selected=true;}form?.addEventListener('submit',(event)=>{event.preventDefault();const data=new FormData(form);const subject=`PVC compound inquiry - ${data.get('product')}`;const body=`Product: ${data.get('product')}\nCompany / contact: ${data.get('contact')}\nReply via: ${data.get('reply')}\n\nApplication and specification:\n${data.get('application')}\n\nPerformance, standard, color and volume:\n${data.get('requirements')}`;location.href=`mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;});</script></BaseLayout><style>.page-eyebrow{margin-bottom:var(--sp-3)}.form-wrap{max-width:760px}.form-wrap form{display:grid;gap:var(--sp-5);padding:var(--sp-7);border:1px solid var(--color-border);border-radius:var(--radius-md);box-shadow:var(--shadow-xs)}label{display:grid;gap:8px;font-weight:700;color:var(--color-primary-dark)}input,select,textarea{width:100%;padding:12px 14px;border:1px solid var(--color-border-strong);border-radius:var(--radius-sm);font:inherit;background:#fff}textarea{resize:vertical}.form-note{font-size:var(--fs-sm);margin:0;color:var(--color-text-soft)}@media(max-width:720px){.form-wrap form{padding:var(--sp-5)}}</style>

